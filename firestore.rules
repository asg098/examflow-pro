rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function hasUserDoc() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return hasUserDoc()
        ? currentUser().role
        : null;
    }

    function isAdmin() {
      return currentRole() == 'admin';
    }

    function sameSchool(schoolId) {
      return hasUserDoc() && schoolId != null && currentUser().schoolId == schoolId;
    }

    function managesSchool(schoolId) {
      return isAdmin() || (currentRole() == 'school' && sameSchool(schoolId));
    }

    function teachesSchool(schoolId) {
      return currentRole() == 'teacher' && sameSchool(schoolId);
    }

    function schoolMember(schoolId) {
      return managesSchool(schoolId) || teachesSchool(schoolId) || (currentRole() in ['student', 'parent'] && sameSchool(schoolId));
    }

    function schoolFromRequest() {
      return request.resource.data.schoolId;
    }

    function schoolFromResource() {
      return resource.data.schoolId;
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if managesSchool(schoolId);
    }

    match /classes/{classId} {
      allow read: if true;
      allow create, update, delete: if managesSchool(schoolFromRequest()) || managesSchool(schoolFromResource());
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        (resource.data.schoolId != null && schoolMember(resource.data.schoolId))
      );

      allow create: if signedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        managesSchool(schoolFromRequest()) ||
        (teachesSchool(schoolFromRequest()) && request.resource.data.role == 'student')
      );

      allow update: if signedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        managesSchool(schoolFromRequest()) ||
        managesSchool(schoolFromResource()) ||
        (teachesSchool(schoolFromRequest()) && request.resource.data.role == 'student') ||
        (teachesSchool(schoolFromResource()) && resource.data.role == 'student')
      );

      allow delete: if isAdmin() || managesSchool(schoolFromResource());
    }

    match /teachers/{teacherId} {
      allow read: if signedIn() && schoolMember(schoolFromResource());
      allow create, update, delete: if managesSchool(schoolFromRequest()) || managesSchool(schoolFromResource());
    }

    match /tests/{testId} {
      allow read: if signedIn() && (
        isAdmin() ||
        schoolMember(schoolFromResource()) ||
        schoolMember(schoolFromRequest())
      );
      allow create, update, delete: if signedIn() && (
        isAdmin() ||
        managesSchool(schoolFromRequest()) ||
        teachesSchool(schoolFromRequest())
      );
    }

    match /results/{resultId} {
      allow read: if signedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.teacherId ||
        schoolMember(schoolFromResource())
      );
      allow create: if signedIn() && (
        isAdmin() ||
        request.auth.uid == request.resource.data.studentId ||
        request.auth.uid == request.resource.data.teacherId ||
        schoolMember(schoolFromRequest())
      );
      allow update, delete: if signedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.teacherId ||
        managesSchool(schoolFromResource())
      );
    }

    match /questionBank/{questionId} {
      allow read: if signedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.teacherId ||
        schoolMember(schoolFromResource())
      );
      allow create, update, delete: if signedIn() && (
        isAdmin() ||
        request.auth.uid == request.resource.data.teacherId ||
        request.auth.uid == resource.data.teacherId ||
        managesSchool(schoolFromRequest()) ||
        managesSchool(schoolFromResource())
      );
    }

    match /certificates/{certId} {
      allow read: if signedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.studentId ||
        schoolMember(schoolFromResource())
      );
      allow create: if signedIn() && (
        isAdmin() ||
        request.auth.uid == request.resource.data.studentId ||
        request.auth.uid == request.resource.data.teacherId ||
        schoolMember(schoolFromRequest())
      );
      allow update, delete: if isAdmin() || managesSchool(schoolFromResource());
    }

    match /students/{studentId} {
      allow read, write: if signedIn() && (isAdmin() || schoolMember(schoolFromResource()) || schoolMember(schoolFromRequest()));
    }
  }
}
