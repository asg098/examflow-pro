rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- BASIC HELPERS ---
    function signedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // --- ROLE & SCHOOL HELPERS ---
    function isAdmin() {
      return signedIn() && request.auth.token.email == 'gandhiatharv565@gmail.com';
    }

    function managesSchool(schoolId) {
      return signedIn() && (isAdmin() || (getUserData().role == 'school' && getUserData().schoolId == schoolId));
    }

    function teachesSchool(schoolId) {
      return signedIn() && (getUserData().role == 'teacher' && getUserData().schoolId == schoolId);
    }

    function schoolMember(schoolId) {
      return signedIn() && (isAdmin() || (getUserData().schoolId == schoolId && (getUserData().role == 'school' || getUserData().role == 'teacher' || getUserData().role == 'student')));
    }

    // --- RULES ---

    // Schools: Public to read names, but only admins create. Admins/SchoolAdmins edit.
    // Schools: Public to read names (for signup discovery), but only admins create.
    match /schools/{schoolId} {
      allow read: if true; // Allow new users to find their school before signing up
      allow create: if isAdmin(); // Only platform admins create schools
      allow update, delete: if managesSchool(schoolId);
    }

    // Classes: Public to read (for signup), school management only for edits
    match /classes/{classId} {
      allow read: if true; // Allow new users to see available classes during signup
      allow create: if managesSchool(request.resource.data.schoolId);
      allow update, delete: if managesSchool(resource.data.schoolId);
    }

    // Users: Critical protection against privilege escalation
    match /users/{userId} {
      // Identity Priority: Users can ALWAYS read their own profile without recursive checks
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      
      // Secondary Access: Allow anyone to read student profiles (for linking/leaderboards)
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.role == 'student' ||
        (resource.data.schoolId != null && resource.data.schoolId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.childEmail == resource.data.email)
      );
      // Create: Users can create their own doc on signup, or admins/schools can create.
      allow create: if signedIn() && (
        (request.auth.uid == userId && request.resource.data.role in ['student', 'teacher', 'parent', 'school']) ||
        isAdmin() ||
        (getUserData().role == 'school' && request.resource.data.schoolId == getUserData().schoolId)
      );

      // Update: Prevent role escalation, but allow parents to link school/child
      allow update: if signedIn() && (
        (request.auth.uid == userId && (
          (resource.data.role == 'parent' && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid'])) ||
          (resource.data.role != 'parent' && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid', 'schoolId']))
        )) ||
        isAdmin() ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'school' && resource.data.schoolId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId)
      );

      allow delete: if isAdmin() || (getUserData().role == 'school' && resource.data.schoolId == getUserData().schoolId);
    }

    // Teachers mapping
    match /teachers/{teacherId} {
      allow read: if signedIn() && (
        schoolMember(resource.data.schoolId) ||
        getUserData().email == resource.data.email
      );
      allow create, update, delete: if managesSchool(request.resource.data.schoolId) || managesSchool(resource.data.schoolId);
    }

    // Tests & Questions
    match /tests/{testId} {
      allow read: if signedIn() && (
        schoolMember(resource.data.schoolId) ||
        resource.data.teacherId == request.auth.uid
      );
      
      allow create: if signedIn() && (
        isAdmin() ||
        managesSchool(request.resource.data.schoolId) ||
        teachesSchool(request.resource.data.schoolId)
      );
      
      allow update: if signedIn() && (
        isAdmin() ||
        managesSchool(resource.data.schoolId) ||
        (teachesSchool(resource.data.schoolId) && resource.data.teacherId == request.auth.uid)
      );

      allow delete: if isAdmin() || managesSchool(resource.data.schoolId);

      // Private Key Security: ABSOLUTELY NO STUDENT ACCESS
      match /private/{docId} {
        allow read, write: if signedIn() && (
          isAdmin() ||
          managesSchool(get(/databases/$(database)/documents/tests/$(testId)).data.schoolId) ||
          teachesSchool(get(/databases/$(database)/documents/tests/$(testId)).data.schoolId)
        );
      }
    }

    // Results: The core of the exam security
    match /results/{resultId} {
      allow read: if signedIn() && (
        isAdmin() ||
        schoolMember(resource.data.schoolId) ||
        resource.data.studentId == request.auth.uid ||
        resource.data.teacherId == request.auth.uid ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent' && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.childId == resource.data.studentId)
      );

      allow create: if signedIn() && (
        // Students can only create their own results and must start as 'pending'
        (request.auth.uid == request.resource.data.studentId && request.resource.data.status == 'pending') ||
        isAdmin() ||
        managesSchool(request.resource.data.schoolId)
      );

      // NO STUDENT UPDATES: Only teachers/admins can grade or delete results
      allow update, delete: if signedIn() && (
        isAdmin() ||
        managesSchool(resource.data.schoolId) ||
        request.auth.uid == resource.data.teacherId
      );
    }

    // Question Bank
    match /questionBank/{questionId} {
      allow read: if signedIn() && (
        isAdmin() ||
        schoolMember(resource.data.schoolId) ||
        resource.data.teacherId == request.auth.uid
      );
      allow create, update, delete: if signedIn() && (
        isAdmin() ||
        managesSchool(request.resource.data.schoolId) ||
        teachesSchool(request.resource.data.schoolId)
      );
    }

    // Certificates
    match /certificates/{certId} {
      allow read: if signedIn() && (
        isAdmin() || 
        schoolMember(resource.data.schoolId) ||
        resource.data.studentId == request.auth.uid ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent' && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.childId == resource.data.studentId)
      );
      allow create: if signedIn() && (
        isAdmin() ||
        managesSchool(request.resource.data.schoolId) ||
        teachesSchool(request.resource.data.schoolId)
      );
      allow delete: if isAdmin();
    }
  }
}
