rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- BASIC HELPERS ---
    function signedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // --- ROLE HELPERS ---
    // Note: We use getUserData() carefully to stay under the 10 get() call limit.
    function currentRole() {
      return hasUserDoc() ? getUserData().role : null;
    }
    
    function isAdmin() {
      return signedIn() && currentRole() == 'admin';
    }

    // --- SCHOOL HELPERS ---
    function userSchoolId() {
      return hasUserDoc() ? getUserData().schoolId : null;
    }

    function sameSchool(schoolId) {
      return signedIn() && schoolId != null && userSchoolId() == schoolId;
    }

    function managesSchool(schoolId) {
      let role = currentRole();
      return isAdmin() || (role == 'school' && sameSchool(schoolId));
    }

    function teachesSchool(schoolId) {
      return currentRole() == 'teacher' && sameSchool(schoolId);
    }

    function schoolMember(schoolId) {
      let role = currentRole();
      return role != null && (isAdmin() || sameSchool(schoolId));
    }

    // --- RULES ---

    match /schools/{schoolId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if managesSchool(schoolId);
    }

    match /classes/{classId} {
      allow read: if true;
      allow create, update, delete: if managesSchool(request.resource.data.schoolId) || managesSchool(resource.data.schoolId);
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        (resource.data.schoolId != null && schoolMember(resource.data.schoolId)) ||
        (currentRole() == 'parent' && getUserData().childEmail == resource.data.email)
      );

      allow create: if signedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        managesSchool(request.resource.data.schoolId) ||
        (teachesSchool(request.resource.data.schoolId) && request.resource.data.role == 'student')
      );

      allow update: if signedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        managesSchool(request.resource.data.schoolId) ||
        managesSchool(resource.data.schoolId) ||
        (teachesSchool(request.resource.data.schoolId) && request.resource.data.role == 'student') ||
        (teachesSchool(resource.data.schoolId) && resource.data.role == 'student')
      );

      allow delete: if isAdmin() || managesSchool(resource.data.schoolId);
    }

    match /teachers/{teacherId} {
      allow read: if signedIn() && (
        schoolMember(resource.data.schoolId) ||
        getUserData().email == resource.data.email
      );
      allow create, update, delete: if managesSchool(request.resource.data.schoolId) || managesSchool(resource.data.schoolId);
    }

    match /tests/{testId} {
      allow read: if signedIn() && (
        isAdmin() ||
        schoolMember(resource.data.schoolId) ||
        schoolMember(request.resource.data.schoolId)
      );
      allow create, update, delete: if signedIn() && (
        isAdmin() ||
        managesSchool(request.resource.data.schoolId) ||
        teachesSchool(request.resource.data.schoolId)
      );
    }

    match /results/{resultId} {
      allow read: if signedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.teacherId ||
        schoolMember(resource.data.schoolId) ||
        (currentRole() == 'parent' && getUserData().childEmail == resource.data.studentEmail)
      );
      allow create: if signedIn() && (
        isAdmin() ||
        request.auth.uid == request.resource.data.studentId ||
        request.auth.uid == request.resource.data.teacherId ||
        schoolMember(request.resource.data.schoolId)
      );
      allow update, delete: if signedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.teacherId ||
        managesSchool(resource.data.schoolId)
      );
    }

    match /questionBank/{questionId} {
      allow read: if signedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.teacherId ||
        schoolMember(resource.data.schoolId)
      );
      allow create, update, delete: if signedIn() && (
        isAdmin() ||
        request.auth.uid == request.resource.data.teacherId ||
        request.auth.uid == resource.data.teacherId ||
        managesSchool(request.resource.data.schoolId) ||
        managesSchool(resource.data.schoolId)
      );
    }

    match /certificates/{certId} {
      allow read: if signedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.studentId ||
        schoolMember(resource.data.schoolId)
      );
      allow create: if signedIn() && (
        isAdmin() ||
        request.auth.uid == request.resource.data.studentId ||
        request.auth.uid == request.resource.data.teacherId ||
        schoolMember(request.resource.data.schoolId)
      );
      allow update, delete: if isAdmin() || managesSchool(resource.data.schoolId);
    }
  }
}
